    },
    {
      "name": "Student",
      "description": "CRUD operations for Student",
      "item": [
        {
          "name": "Create Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/student",
              "host": ["{{baseUrl}}"],
              "path": ["student"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentName\": \"Alice Smith\",\n  \"age\": 15,\n  \"course\": \"Mathematics\",\n  \"branchId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Create a new student. studentName, age (min 1) and branchId are required."
          }
        },
        {
          "name": "Update Student",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
