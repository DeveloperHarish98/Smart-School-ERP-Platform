              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/student/1",
              "host": ["{{baseUrl}}"],
              "path": ["student", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentName\": \"Alice Johnson\",\n  \"age\": 16,\n  \"course\": \"Physics\",\n  \"branchId\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Update student by ID."
          }
        },
