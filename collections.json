{
  "info": {
    "_postman_id": "demo-school-api-collection",
    "name": "Demo School Management API",
    "description": "Postman collection for all REST APIs in the Spring Boot Demo project — Auth, School, Branch, Student, File Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token — set this after login"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints — register and login",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"USER\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Register a new user. Role can be: ADMIN, TEACHER, STUDENT, USER"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "  pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Login and receive JWT token. Token is auto-saved to {{token}} collection variable."
          }
        }
      ]
    },
    {
      "name": "School",
      "description": "CRUD operations for School",
      "item": [
        {
          "name": "Create School",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/schools",
              "host": ["{{baseUrl}}"],
              "path": ["schools"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schoolName\": \"Springfield Elementary\",\n  \"location\": \"Springfield\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Create a new school. schoolName and location are required."
          }
        },
        {
          "name": "Update School",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/schools/1",
              "host": ["{{baseUrl}}"],
              "path": ["schools", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schoolName\": \"Updated School Name\",\n  \"location\": \"New Location\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Update school by ID."
          }
        },
        {
          "name": "Get School By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/schools/1",
              "host": ["{{baseUrl}}"],
              "path": ["schools", "1"]
            },
            "description": "Get a single school by its ID."
          }
        },
        {
          "name": "Get All Schools (Paginated)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/schools?page=0&size=5",
              "host": ["{{baseUrl}}"],
              "path": ["schools"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "5"
                }
              ]
            },
            "description": "Get all schools with pagination."
          }
        },
        {
          "name": "Delete School",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/schools/1",
              "host": ["{{baseUrl}}"],
              "path": ["schools", "1"]
            },
            "description": "Delete school by ID."
          }
        },
        {
          "name": "Find School By Name",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/schools/SchoolName?schoolName=Springfield Elementary",
              "host": ["{{baseUrl}}"],
              "path": ["schools", "SchoolName"],
              "query": [
                {
                  "key": "schoolName",
                  "value": "Springfield Elementary"
                }
              ]
            },
            "description": "Find school by school name (query param). Example: /schools/SchoolName?schoolName=Springfield Elementary"
          }
        },
        {
          "name": "Find School By Location",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/schools/LocationName?schoolLocation=Springfield",
              "host": ["{{baseUrl}}"],
              "path": ["schools", "LocationName"],
              "query": [
                {
                  "key": "schoolLocation",
                  "value": "Springfield"
                }
              ]
            },
            "description": "Find school by location (query param). Example: /schools/LocationName?schoolLocation=Springfield"
          }
        }
      ]
    },
