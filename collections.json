              "path": ["student"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "5"
                }
              ]
            },
            "description": "Get all students with pagination. Defaults: page=0, size=5."
          }
