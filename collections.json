    },
    {
      "name": "File Management",
      "description": "Upload, download and list files. Files are saved to disk and metadata stored in DB (file_metadata table).",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/files/upload",
              "host": ["{{baseUrl}}"],
              "path": ["files", "upload"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select the file to upload"
                }
              ]
            },
            "description": "Upload a file (multipart/form-data, key='file'). Returns DB record: { id, originalFileName, storedFileName, contentType, fileSize, uploadedAt, downloadUrl }."
          }
        },
        {
          "name": "Download File",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/files/download/example.pdf",
              "host": ["{{baseUrl}}"],
              "path": ["files", "download", "example.pdf"]
            },
            "description": "Download a file by its storedFileName. Path is looked up from the DB. Replace 'example.pdf' with the storedFileName returned by the Upload endpoint."
          }
        },
        {
          "name": "List All Uploaded Files",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/files",
              "host": ["{{baseUrl}}"],
              "path": ["files"]
            },
            "description": "Returns all file records from the file_metadata table in the DB."
          }
        }
      ]
    }
  ]
}
